# Server Environment Variables
# Copy this file to .env and fill in the values

# Server port
PORT=8080

# JWT secret for authentication (generate a strong random string for production)
JWT_SECRET=

# Redis URL for pub/sub and presence
REDIS_URL=redis://127.0.0.1:6379

# Public base URL of the server (used for upload URLs)
PUBLIC_BASE_URL=http://localhost:8080

# AI configuration
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# MySQL configuration
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=navo_im

# CORS origin (set to your frontend domain in production)
# CORS_ORIGIN=http://localhost:5173

# ICE server configuration for WebRTC
# Comma-separated STUN/TURN URLs
# STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# TURN server (optional, required for users behind symmetric NATs)
# TURN_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=your-turn-username
# TURN_CREDENTIAL=your-turn-password

# Debug logging (set to 1 to enable SFU debug logs)
# DEBUG_SFU=1
